# Copy this file to .env.agent and set the values below.
# See SETUP.md for the rationale.

# NotebookLM notebook UUID (exact match, more robust than name-based
# matching). Get the UUID from the URL of your notebook in NotebookLM
# (e.g. https://notebooklm.google.com/notebook/<UUID>). The notebook
# should contain authoritative sources for streaming standards:
# MPEG-DASH 6th edition, HLS, C2PA, DRM, IAB CTV, SCTE-35.
NOTEBOOK_ID=

# Stage 5 — GitHub issues pipeline.
# Comma-separated list of GitHub usernames whose issues the pipeline
# can process and respond to end-to-end automatically. Issues from
# outsiders (anyone NOT in this list) still get triaged + drafted, but
# the response is held with label `ai-needs-review` and Nicolas
# decides manually whether to post it (and optionally promote the
# author into TRUSTED_GH_USERS).
TRUSTED_GH_USERS=nicolaslevy,emilsas
