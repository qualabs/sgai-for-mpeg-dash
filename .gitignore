# Local agent configuration — contains user-specific notebook names
.env.agent

# Editor artifacts
.DS_Store
*.swp
*.swo
*~

# Build outputs that are heavy and re-generable (optional)
# output/*.md      # uncomment if you want output/ excluded

# Stage 5 — GitHub issues pipeline scratch (per-issue triage / impact /
# response drafts). The repo never commits these; the canonical place
# for posted responses is GitHub itself. The .gitkeep is whitelisted so
# the empty directory is preserved.
/.github-ai/output-issues/*
!/.github-ai/output-issues/.gitkeep

# Stage 6 — GitHub PRs pipeline scratch (per-PR triage / analyze /
# review drafts). Same pattern as Stage 5: posted reviews live on
# GitHub; the local scratch is never committed. The .gitkeep is
# whitelisted so the empty directory survives checkouts.
/.github-ai/output-prs/*
!/.github-ai/output-prs/.gitkeep
